{
  "name": "watai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Watai — a ChatGPT-style web app powered by your own Azure OpenAI endpoint (BYO key).",
  "scripts": {
    "dev": "vite",
    "lint:ds": "node scripts/check-design-system.mjs",
    "build": "npm run lint:ds && tsc -b && vite build",
    "build:nocheck": "vite build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.15.0",
    "@microsoft/signalr": "^10.0.0",
    "idb": "^8.0.0",
    "katex": "^0.16.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.26.2",
    "rehype-highlight": "^7.0.0",
    "rehype-katex": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^25.0.1",
    "playwright": "^1.61.1",
    "storybook": "^8.6.14",
    "typescript": "^5.5.4",
    "vite": "^5.4.6",
    "vitest": "^2.1.9"
  }
