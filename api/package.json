{
  "name": "watai-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "description": "Watai API (Azure Functions): server-authoritative generation + encrypted credential vault. Persists threads/messages/runs in Cosmos and runs Azure OpenAI server-side.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "memory:smoke": "npx --yes tsx scripts/memory-smoke.ts",
    "eval": "npx --yes tsx scripts/memory-eval.ts",
    "embed-check": "npx --yes tsx scripts/embed-check.ts",
    "voice-check": "npx --yes tsx scripts/voice-check.ts",
    "library:inventory": "npx --yes tsx scripts/library-inventory.ts",
    "library:backfill": "npx --yes tsx scripts/library-backfill.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node20 --packages=external --outfile=dist/index.cjs",
    "prestart": "npm run build",
    "start": "func start"
  },
  "dependencies": {
    "@azure/cosmos": "^4.9.3",
    "@azure/functions": "^4.16.1",
    "@azure/identity": "^4.13.1",
    "@azure/keyvault-keys": "^4.10.2",
    "@azure/storage-blob": "^12.32.0",
    "@azure/storage-queue": "^12.31.0",
    "fflate": "^0.8.3",
    "jose": "^5.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
