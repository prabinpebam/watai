{
  "name": "watai-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "description": "Watai persistence API (Azure Functions). Two-plane architecture: never handles the user's Azure OpenAI key.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node20 --packages=external --outfile=dist/index.cjs",
    "prestart": "npm run build",
    "start": "func start"
  },
  "dependencies": {
    "@azure/cosmos": "^4.9.3",
    "@azure/functions": "^4.16.1",
    "@azure/identity": "^4.13.1",
    "@azure/storage-blob": "^12.32.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
