{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": { "isEnabled": true, "excludedTypes": "Request" }
    }
  },
  "extensions": {
    "queues": {
      "maxPollingInterval": "00:00:01",
      "batchSize": 16,
      "newBatchThreshold": 8,
      "visibilityTimeout": "00:00:30"
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  }
}
